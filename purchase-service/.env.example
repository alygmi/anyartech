APP_NAME=PurchaseService
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db_purchasing
DB_PORT=3306
DB_DATABASE=db_purchasing
DB_USERNAME=root
DB_PASSWORD=secret

# URL Auth Service di dalam Docker network
# Dipakai middleware untuk validasi JWT token
AUTH_SERVICE_URL=http://auth-service:8080
AUTH_SERVICE_TIMEOUT=5

# Employee Service (HRIS) — sumber data cabang
EMPLOYEE_SERVICE_URL=http://employee-service:8002
EMPLOYEE_SERVICE_TIMEOUT=10
EMPLOYEE_SERVICE_CACHE_TTL=300

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
SESSION_DRIVER=redis

JWT_SECRET=
