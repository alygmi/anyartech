# ============================================================
# Root .env — dipakai oleh docker-compose.yml
# Copy file ini ke .env dan isi nilainya
# ============================================================

# Password MySQL untuk semua database (bisa dibedakan per service kalau mau)
MYSQL_ROOT_PASSWORD=secret

# App key Laravel untuk masing-masing service
# Generate dengan: php artisan key:generate --show
AUTH_APP_KEY=base64:h1NKHbVKlpylQZVsemTg3npGzpu6jNO6pDodvtKcZx8=
EMPLOYEE_APP_KEY=base64:GENERATE_ME
PURCHASING_APP_KEY=base64:GENERATE_ME

# JWT Secret — satu secret dipakai semua service (karena satu centralized auth)
# Generate dengan: php artisan jwt:secret --show
JWT_SECRET=89SuHK7aPqSGgQ6A7SxJlJ02dJWXeChSvwNfpacotcLMTyI8CM1dThOjQYNvJTJV
